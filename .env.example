# Supabase 설정
# https://supabase.com 에서 프로젝트 생성 후 아래 값을 채워주세요
VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# 암호화 키 (클라이언트 사이드 암호화용)
# 브라우저 콘솔에서 crypto.randomUUID() 실행해서 생성하세요
# 이 키를 바꾸면 기존에 암호화된 글을 읽을 수 없게 됩니다!
VITE_ENCRYPTION_KEY=your-random-key-here
